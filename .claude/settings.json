{
  "permissions": {
    "allow": [
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git credential *)",
      "Bash(git config *)",
      "Bash(git init:*)",
      "Bash(git remote:*)",
      "Bash(git pull:*)",
      "Bash(grep:*)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Skill(accept-many)",
      "Skill(accept-one)",
      "Skill(search-to-sheet)"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git status --porcelain 2>/dev/null | grep -q . && printf '{\"systemMessage\":\"You have uncommitted changes — consider committing before closing.\"}' || true"
          }
        ]
      }
    ]
  }
}
